#!/bin/bash
#
# Pre-commit hook för samhallsanalys-rapporter.
#
# För varje staged HTML-fil i public/<rapportnamn>/ letas en källfil
# <rapportnamn>.qmd eller <rapportnamn>.Rmd upp i syster-repot
# c:/gh/<rapportnamn>/ (samma föräldermapp som detta repo ligger i).
# Om en sådan källfil finns OCH är nyare än HTML-filen avbryts commiten.
#
# Icke-interaktiv: avbryter direkt vid stale HTML, inga prompts.
# Kringgås med `git commit --no-verify` om man medvetet vill commita en
# gammal version.
#
# Aktiveras genom att köra (en gång per klon):
#   git config core.hooksPath .githooks

set -e

repo_root=$(git rev-parse --show-toplevel)
gh_root=$(dirname "$repo_root")

staged_html=$(git diff --cached --name-only --diff-filter=ACM | grep -E '^public/.*\.html?$' || true)
[[ -z "$staged_html" ]] && exit 0

errors=0

while IFS= read -r file; do
  [[ -f "$file" ]] || continue

  # public/<rapportnamn>/index.html  →  <rapportnamn>
  rel="${file#public/}"
  rapportnamn="${rel%%/*}"

  # Leta källfil i syster-repot c:/gh/<rapportnamn>/
  src=""
  for ext in qmd Rmd rmd; do
    cand="$gh_root/$rapportnamn/$rapportnamn.$ext"
    if [[ -f "$cand" ]]; then
      src="$cand"
      break
    fi
  done

  # Ingen källfil hittad — kan inte jämföra, hoppa över
  [[ -z "$src" ]] && continue

  html_mtime=$(stat -c %Y "$file" 2>/dev/null || stat -f %m "$file")
  src_mtime=$( stat -c %Y "$src"  2>/dev/null || stat -f %m "$src")

  if (( html_mtime < src_mtime )); then
    echo "FEL: $file är äldre än källfilen $src — rendera om innan commit." >&2
    errors=$((errors + 1))
  fi
done <<< "$staged_html"

if (( errors > 0 )); then
  echo "" >&2
  echo "Commit avbruten. Kör 'git commit --no-verify' om du medvetet vill commita ändå." >&2
  exit 1
fi

exit 0