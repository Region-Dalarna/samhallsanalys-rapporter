#!/bin/bash
#
# Pre-commit hook för samhallsanalys-rapporter.
#
# Varnar om HTML-filer som ska commitas i public/ verkar inaktuella
# (filens mtime är äldre än några dagar). Syftet är att fånga upp
# de fall där man glömt att rendera om rapporten innan commit.
#
# Hooken kan kringgås med:  git commit --no-verify
#
# Aktiveras genom att köra (en gång per klon):
#   git config core.hooksPath .githooks

set -e

STALE_THRESHOLD_DAYS=7

# Hitta .html-filer som är staged i public/
staged_html=$(git diff --cached --name-only --diff-filter=ACM | grep -E '^public/.*\.html?$' || true)

if [[ -z "$staged_html" ]]; then
  exit 0
fi

now=$(date +%s)
warnings=0

while IFS= read -r file; do
  [[ -f "$file" ]] || continue

  # Filens mtime (Linux: stat -c, macOS: stat -f)
  mtime=$(stat -c %Y "$file" 2>/dev/null || stat -f %m "$file" 2>/dev/null || echo "$now")
  age_days=$(( (now - mtime) / 86400 ))

  if (( age_days > STALE_THRESHOLD_DAYS )); then
    echo "VARNING: $file är $age_days dagar gammal — har du glömt att rendera om?" >&2
    warnings=$((warnings + 1))
  fi
done <<< "$staged_html"

if (( warnings > 0 )); then
  echo "" >&2
  echo "Hittade $warnings potentiellt inaktuell(a) HTML-fil(er)." >&2
  echo "Fortsätt ändå? [y/N] " >&2
  exec < /dev/tty
  read -r answer
  if [[ "$answer" != "y" && "$answer" != "Y" ]]; then
    echo "Commit avbruten." >&2
    exit 1
  fi
fi

exit 0
